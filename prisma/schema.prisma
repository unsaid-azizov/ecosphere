// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  INDIVIDUAL // Физическое лицо
  IP         // ИП
  OOO        // ООО/Юридическое лицо
}

enum OrderStatus {
  PENDING    // Ожидает обработки
  CONFIRMED  // Подтвержден
  PROCESSING // В обработке
  SHIPPED    // Отправлен
  DELIVERED  // Доставлен
  CANCELLED  // Отменен
}

enum UserRole {
  USER       // Обычный пользователь
  MANAGER    // Менеджер (только чтение)
  ADMIN      // Администратор (полный доступ)
}

enum DiscountType {
  PRODUCT   // Скидка на конкретный товар
  CATEGORY  // Скидка на категорию товаров
  ALL       // Скидка на все товары
}

enum PostStatus {
  DRAFT     // Черновик
  PUBLISHED // Опубликован
  ARCHIVED  // Архивирован
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  userType  UserType
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Физическое лицо
  firstName String?
  lastName  String?
  phone     String?

  // ИП
  ipName String? // Наименование ИП

  // ООО
  companyName   String? // Наименование организации
  legalAddress  String? // Юридический адрес

  // Общие для ИП и ООО
  inn String? // ИНН
  kpp String? // КПП (для ООО)

  // Скидки и специальные цены
  discountPercent Int     @default(0) // Процент скидки
  isVip           Boolean @default(false) // VIP статус
  specialPrices   UserSpecialPrice[] // Персональные цены на товары

  // Связи
  orders           Order[]
  favorites        Favorite[]
  cartItems        CartItem[]
  loyaltyPoints    Int        @default(0) // Баллы лояльности
  personalDiscounts PersonalDiscount[] // Персональные скидки для пользователя
  createdDiscounts PersonalDiscount[] @relation("CreatedDiscounts") // Скидки, созданные пользователем (если админ)
  posts            Post[] // Посты в блоге, созданные пользователем

  @@map("users")
}

model UserSpecialPrice {
  id        String @id @default(cuid())
  userId    String
  productId String // ID товара из CSV
  price     Float  // Специальная цена
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("user_special_prices")
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique // Номер заказа для пользователя
  userId      String
  status      OrderStatus @default(PENDING)
  totalAmount Float
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  // Контактная информация
  contactEmail String
  contactPhone String?
  deliveryAddress String?

  // Связи
  user      User        @relation(fields: [userId], references: [id])
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  productId String // ID товара из CSV
  quantity  Int
  price     Float // Цена на момент заказа
  createdAt DateTime @default(now())

  // Информация о товаре на момент заказа
  productName     String
  productCategory String
  productArticle  String

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_items")
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  productId String   // ID товара из CSV
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("favorites")
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String   // ID товара из CSV
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart_items")
}

// Модель для хранения инвентаря товаров
model ProductInventory {
  id            String   @id @default(cuid())
  productId     String   @unique // ID товара из CSV
  stockQuantity Int      @default(0)
  minStock      Int      @default(5) // Минимальный остаток
  maxStock      Int      @default(100) // Максимальный остаток
  updatedAt     DateTime @updatedAt

  @@map("product_inventory")
}

// Модель для персонализированных скидок
model PersonalDiscount {
  id              String   @id @default(cuid())
  name            String   // Название скидки (например, "VIP скидка для Иванова")
  description     String?  // Описание скидки
  
  // Кому применяется скидка
  userId          String?  // Конкретный пользователь (null = для всех)
  userType        UserType? // Тип пользователя (INDIVIDUAL, IP, OOO)
  
  // На что применяется скидка
  discountType    DiscountType // PRODUCT, CATEGORY, ALL
  productId       String?  // Конкретный товар (если discountType = PRODUCT)
  category        String?  // Категория товаров (если discountType = CATEGORY)
  
  // Параметры скидки
  discountPercent Int      // Процент скидки (1-99)
  
  // Временные ограничения
  validFrom       DateTime @default(now())
  validUntil      DateTime?
  
  // Статус
  isActive        Boolean  @default(true)
  
  // Метаданные
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String   // ID администратора, создавшего скидку
  
  // Связи
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  creator         User     @relation("CreatedDiscounts", fields: [createdBy], references: [id])

  @@map("personal_discounts")
}

// Модель для скидок на товары (оставляем для совместимости)
model ProductDiscount {
  id          String   @id @default(cuid())
  productId   String   @unique // ID товара из CSV
  discountPercent Int  // Процент скидки
  validFrom   DateTime @default(now())
  validUntil  DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@map("product_discounts")
}

// Модель для хранения товаров в базе данных
model Product {
  id          String   @id // Артикул товара
  name        String   // Название товара
  description String?  // Описание товара
  price       Float    // Цена
  category    String   // Категория
  images      String[] // Массив ссылок на изображения
  article     String   // Артикул (может отличаться от id)
  
  // Количество в наличии
  stockQuantity Int      @default(0)
  isAvailable   Boolean  @default(true)
  
  // Метаданные
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("products")
}

// Модель для блога
model Post {
  id          String     @id @default(cuid())
  title       String     // Заголовок поста
  slug        String     @unique // URL-friendly версия заголовка
  excerpt     String?    // Краткое описание/анонс
  content     String     @db.Text // Содержание поста (markdown)
  contentType String     @default("markdown") // Тип контента: "markdown" или "blocks"
  blocks      Json?      // Блочная структура контента (JSON)
  coverImage  String?    // Обложка поста
  images      String[]   // Дополнительные изображения
  
  // Метаданные
  status      PostStatus @default(DRAFT)
  featured    Boolean    @default(false) // Рекомендуемый пост
  views       Int        @default(0) // Количество просмотров
  
  // Категоризация
  category    String?    // Категория поста
  tags        String[]   // Теги
  
  // SEO
  metaTitle       String? // SEO заголовок
  metaDescription String? // SEO описание
  
  // Временные метки
  publishedAt DateTime?  // Дата публикации
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  
  // Автор
  authorId    String
  author      User       @relation(fields: [authorId], references: [id])
  
  @@map("posts")
}